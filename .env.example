# tracking-api (workers/) env vars — Sprint 0 feature F (Auto-Provisioner GTM)

# Redis (Easypanel KV8 internal). Storage backend usa esse URL.
REDIS_URL=redis://redis:6379

# Storage backend selector — 'redis' (MVP F) ou 'supabase' (Onda 1.5, ainda não impl).
STORAGE_BACKEND=redis

# libsodium sealed box keypair pra cifrar tokens/passwords at-rest em Redis.
# Gerar via: npx tsx scripts/generate-libsodium-keypair.ts
# Colar as 2 linhas resultantes no Easypanel → tracking-api → Env tab. NÃO commitar valores reais.
STORAGE_ENCRYPTION_PUBLIC_KEY=
STORAGE_ENCRYPTION_SECRET_KEY=
