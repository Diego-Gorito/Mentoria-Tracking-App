# tracking-api (workers/) env vars — Sprint 0 feature F (Auto-Provisioner GTM)

# Redis (Easypanel KV8 internal). Storage backend usa esse URL.
REDIS_URL=redis://redis:6379

# Storage backend selector — 'redis' (MVP F) ou 'supabase' (Onda 1.5, ainda não impl).
STORAGE_BACKEND=redis

# libsodium sealed box keypair pra cifrar tokens/passwords at-rest em Redis.
# Gerar via: npx tsx scripts/generate-libsodium-keypair.ts
# Colar as 2 linhas resultantes no Easypanel → tracking-api → Env tab. NÃO commitar valores reais.
STORAGE_ENCRYPTION_PUBLIC_KEY=
STORAGE_ENCRYPTION_SECRET_KEY=

# === GTM Master Clone (Era 2 — ADR-0009) ===

# Service Account key JSON (prod). Conteúdo completo do JSON da SA
# tracking-claude-sa@n8n-integrar-gmail-sheet-drive.iam.gserviceaccount.com.
# NÃO commitar valor real — colar no Easypanel Env tab.
# ALTERNATIVA: GTM_SA_KEY_PATH abaixo (dev local).
GTM_SA_KEY_JSON=

# Path filesystem do JSON key (dev local). Ignorado em prod se GTM_SA_KEY_JSON setado.
# Ex local: GTM_SA_KEY_PATH=/Volumes/SSD 2T/Dev/tracking-claude-sa.json
GTM_SA_KEY_PATH=

# Conta GTM destino dos clones. Atualmente 6059193756 = GTM | Colégio Mentoria.
GTM_ACCOUNT_ID=6059193756

# Base URL do sGTM compartilhado multi-tenant. Cliente acessa via path /{tenant_slug}.
GTM_SERVER_BASE_URL=https://sgtm.colegiomentoria.com.br
